root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

indent_style = space
indent_size = 4
tab_width = 4
continuation_indent_size = 4

max_line_length = off

[*.{cpp,c,h,hpp}]
indent_style = space
indent_size = 4
tab_width = 4
continuation_indent_size = 4

curly_bracket_next_line = false

c_pointer_alignment = left

allow_short_if = true
allow_short_case = true

trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
max_line_length = off